#!/usr/bin/env bash

# Update version across the project.
# Single source of truth: build.zig.zon
# build.zig reads it via @embedFile at comptime, so no separate version file needed.

update() {
  local version="$1"

  sed -i 's/[.]version = "[^"]*"/.version = "'"$version"'"/g' build.zig.zon
  sed -i 's/PKG_VERSION=.*/PKG_VERSION='"$version"'/g' builder-env
}

update "$@"
